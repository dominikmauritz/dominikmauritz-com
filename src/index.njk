{% set posts = collections.blog | reverse %}
{% if posts | length %}
  <section class="home-posts">
    <p class="eyebrow">Latest Posts</p>
    <ol class="post-list post-list-home">
      {% for post in posts %}
        <li>
          <article class="post-preview post-preview-home">
            <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
            <p class="post-preview__meta">{{ post.date | readableDate }}</p>
          </article>
        </li>
      {% endfor %}
    </ol>
  </section>
{% endif %}
