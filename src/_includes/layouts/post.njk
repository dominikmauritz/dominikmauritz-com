---
layout: layouts/base.njk
section: blog
cardClass: prose-page
showSiteNav: false
---
<article class="post">
  <h1 class="page-title">{{ title }}</h1>
  <p class="post-meta">{{ date | readableDate }}</p>
  <div class="prose">
    {{ content | replace('<a href="http', '<a target="_blank" rel="noreferrer noopener" href="http') | safe }}
  </div>
</article>
