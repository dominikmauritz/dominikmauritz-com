---
layout: layouts/base.njk
section: blog
cardClass: prose-page
showSiteNav: false
---
<article class="post">
  {% set shareUrl = site.url + page.url %}
  {% set shareTitle = title + " | " + site.title %}
  <h1 class="page-title">{{ title }}</h1>
  <p class="post-meta">{{ date | readableDate }}</p>
  <div class="prose">
    {{ content | replace('<a href="http', '<a target="_blank" rel="noreferrer noopener" href="http') | safe }}
  </div>
  <section class="post-share" aria-label="Share this post">
    <p class="post-share__label">Share</p>
    <div class="post-share__links">
      <a href="https://twitter.com/intent/tweet?text={{ shareTitle | encodeURIComponent }}&url={{ shareUrl | encodeURIComponent }}" target="_blank" rel="noreferrer noopener" aria-label="Share on X">
        <svg viewBox="0 0 40 40" aria-hidden="true">
          <path d="M23.6 16.9 33.1 6h-2.3l-8.2 9.4L16 6H8.3l9.9 14.1L8.3 31.4h2.3l8.6-9.9 6.9 9.9h7.7L23.6 16.9Zm-3.3 3.8-1-1.4-8.3-11.9h3.5l6.7 9.5 1 1.4 8.7 12.4h-3.5l-7.1-10Z" />
        </svg>
      </a>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ shareUrl | encodeURIComponent }}" target="_blank" rel="noreferrer noopener" aria-label="Share on LinkedIn">
        <svg viewBox="0 0 40 40" aria-hidden="true">
          <path d="M12.1 13.8v19.1H5.7V13.8Zm.4-5.9c0 .9-.3 1.7-1 2.4-.7.6-1.5.9-2.6.9h0c-1.1 0-1.9-.3-2.5-.9-.6-.6-1-1.4-1-2.4 0-1 .3-1.7 1-2.4S7.9 4.6 9 4.6s1.9.3 2.6.9 1 1.4 1 2.4ZM35 22v11h-6.4V22.7c0-1.4-.3-2.4-.8-3.2-.5-.8-1.3-1.1-2.4-1.1-.8 0-1.5.2-2 .7-.5.4-1 1-1.2 1.7-.1.4-.2.9-.2 1.6v10.7h-6.4c0-5.1 0-9.3 0-12.5s0-5.1 0-5.7l0-.9H22v2.8h0c.3-.4.5-.8.8-1.1.3-.3.6-.6 1.1-1 .5-.4 1-.6 1.7-.8.7-.2 1.4-.3 2.2-.3 2.2 0 4 .7 5.3 2.2C34.4 17 35 19.1 35 22Z" />
        </svg>
      </a>
      <a href="mailto:?subject={{ shareTitle | encodeURIComponent }}&body={{ shareUrl | encodeURIComponent }}" aria-label="Share by email">
        <svg viewBox="0 0 40 40" aria-hidden="true">
          <path d="M6 10.5h28c1.1 0 2 .9 2 2v15c0 1.1-.9 2-2 2H6c-1.1 0-2-.9-2-2v-15c0-1.1.9-2 2-2Zm14 11.2 12-8.9H8l12 8.9Zm0 3.2L6.5 14.8v12.4h27V14.8L20 24.9Z" />
        </svg>
      </a>
      <button class="post-share__copy" type="button" data-share-url="{{ shareUrl }}" aria-label="Copy link">
        <svg viewBox="0 0 40 40" aria-hidden="true">
          <path d="M14 11.5c0-2.2 1.8-4 4-4h9.5c2.2 0 4 1.8 4 4V21c0 2.2-1.8 4-4 4H18c-2.2 0-4-1.8-4-4v-9.5Zm4-1.2c-.7 0-1.2.5-1.2 1.2V21c0 .7.5 1.2 1.2 1.2h9.5c.7 0 1.2-.5 1.2-1.2v-9.5c0-.7-.5-1.2-1.2-1.2H18Zm-9.5 9.2c0-2.2 1.8-4 4-4v2.8c-.7 0-1.2.5-1.2 1.2V29c0 .7.5 1.2 1.2 1.2H22c.7 0 1.2-.5 1.2-1.2H26c0 2.2-1.8 4-4 4h-9.5c-2.2 0-4-1.8-4-4v-9.5Z" />
        </svg>
      </button>
    </div>
    <p class="post-share__status" aria-live="polite"></p>
  </section>
</article>
<script>
  document.querySelectorAll("[data-share-url]").forEach((button) => {
    button.addEventListener("click", async () => {
      const status = button.closest(".post-share")?.querySelector(".post-share__status");

      try {
        await navigator.clipboard.writeText(button.dataset.shareUrl);
        if (status) status.textContent = "Copied";
        setTimeout(() => {
          if (status) status.textContent = "";
        }, 1600);
      } catch {
        if (status) status.textContent = "Copy failed";
      }
    });
  });
</script>
