<!DOCTYPE html>
<html lang="en">
  <head>
    {% set socialImage = site.url + "/card-social-20260519-v2.png" %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if page.url == "/" %}{{ site.title }}{% else %}{{ title }} | {{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="color-scheme" content="dark only" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:title" content="{% if page.url == "/" %}{{ site.title }}{% else %}{{ title }} | {{ site.title }}{% endif %}" />
    <meta property="og:type" content="{{ ogType or 'website' }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:image" content="{{ socialImage }}" />
    <meta property="og:image:secure_url" content="{{ socialImage }}" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="670" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    {% if author %}
      <meta name="author" content="{{ author }}" />
      <meta property="article:author" content="{{ author }}" />
    {% endif %}
    {% if date %}
      <meta property="article:published_time" content="{{ date | isoDate }}" />
    {% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="{{ socialImage }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    {% if ogType == "article" %}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": {{ title | dump | safe }},
          "description": {{ (description or site.description) | dump | safe }},
          "author": {
            "@type": "Person",
            "name": {{ author | dump | safe }}
          },
          "datePublished": "{{ date | isoDate }}",
          "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
          "image": "{{ socialImage }}",
          "publisher": {
            "@type": "Person",
            "name": {{ site.title | dump | safe }}
          }
        }
      </script>
    {% endif %}
    <style>{{ inlineCss | safe }}</style>
  </head>
  <body class="{{ pageClass or 'page-shell' }}">
    <div class="page-frame">
      {% if showSiteHeader != false %}
        <header class="site-header">
          <a class="site-brand" href="/">Dominik Mauritz</a>
          {% if showSiteNav != false %}
            <nav class="site-nav" aria-label="Primary">
              <a href="/" {% if section == "home" %}aria-current="page"{% endif %}>Home</a>
              <a href="/blog/" {% if section == "blog" %}aria-current="page"{% endif %}>Blog</a>
            </nav>
          {% endif %}
        </header>
      {% endif %}
      <main class="site-main {{ cardClass or '' }}">
        {{ content | safe }}
      </main>
    </div>
  </body>
</html>
